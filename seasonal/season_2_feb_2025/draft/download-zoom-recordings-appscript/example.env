# Zoom API credentials
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_USER_ID=me  # or your specific user ID

# Google Drive settings
DRIVE_FOLDER=Zoom Recordings

# Google Sheets tracking
ENABLE_SHEETS_TRACKING=false
SHEET_ID=  # Will be set automatically when sheet is created

# Email notifications
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_FROM=your.email@gmail.com
EMAIL_TO=your.email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_app_password_here  # Generate in Google Account settings 